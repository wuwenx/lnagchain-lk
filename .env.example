# LangChain + 飞书(Lark) 集成
# 复制为 .env 并填写真实值

# 飞书开放平台 - 企业自建应用
# https://open.feishu.cn/app
FEISHU_APP_ID=cli_xxxxxxxxxxxxx
FEISHU_APP_SECRET=your_app_secret_here
FEISHU_DOMAIN=
FEISHU_VERIFICATION_TOKEN=bgQPsx3lg4ZPNwEN6ywX6cbvY1cJbr5B


# LLM：OpenAI 兼容 API（如 OpenAI / 国内中转）

# 可选：群聊访问模式 open | allowlist | disabled
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_API_KEY=sk-xxxxxxxxxxxxx
OPENAI_MODEL=

# jeniya.cn 中转（OpenAI 兼容）


CMC_API_KEY=
FEISHU_DOC_BASE_URL=


JKS_URL=https://jks.popfun.xyz
JKS_USERNAME=
JKS_TOKEN=
JKS_JOB_NAME=test/web/web-mm-admin-new


# GitLab Webhook → 飞书 MR/Push 卡片（可选）
# GitLab Webhooks 里填的 Secret token，不填则不校验
GITLAB_WEBHOOK_SECRET=
# 接收 MR/Push 通知的飞书群 chat_id（机器人需在该群）
FEISHU_MR_CHAT_ID=

# Push 卡片：回滚 tag 默认（commit 中未写「回滚tag xxx」时使用）
GITLAB_PUSH_ROLLBACK_TAG=PROD-20260205-maintainOuerDepth



