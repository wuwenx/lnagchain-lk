# LangChain + 飞书(Lark) 集成
# 复制为 .env 并填写真实值

# 飞书开放平台 - 企业自建应用
# https://open.feishu.cn/app
FEISHU_APP_ID=cli_xxxxxxxxxxxxx
FEISHU_APP_SECRET=your_app_secret_here

# LLM：OpenAI 兼容 API（如 OpenAI / DeepSeek / 国内中转）
OPENAI_API_KEY=sk-xxxxxxxxxxxxx
OPENAI_API_BASE=https://api.openai.com/v1
# 模型名。DeepSeek 示例：OPENAI_API_BASE=https://api.deepseek.com/v1 OPENAI_MODEL=deepseek-chat
# OPENAI_MODEL=gpt-4o-mini

# 可选：群聊访问模式 open | allowlist | disabled
# FEISHU_GROUP_ACCESS=open

# 国际版 Lark 必填（国内飞书可省略）
# FEISHU_DOMAIN=https://open.larksuite.com

# ---------- Webhook 模式（请求地址）----------
# 事件配置里「将事件发送至开发者服务器」时必填
FEISHU_VERIFICATION_TOKEN=bgQPsx3lg4ZPNwEN6ywX6cbvY1cJbr5B
# 若在事件配置里开启了「加密」，需填写 Encrypt Key
# FEISHU_ENCRYPT_KEY=your_encrypt_key

# Webhook 服务端口与路径（请求地址 = 公网URL + WEBHOOK_PATH）
# WEBHOOK_PORT=9000
# WEBHOOK_PATH=/
